// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Prisma 7 setup:
//   • The new `prisma-client` generator emits into ../src/generated/prisma.
//     `moduleFormat = "cjs"` keeps the generated client CommonJS so NestJS
//     needs NO ESM migration. Consumers import it via the src/prisma/client.ts
//     barrel (single place to update if the output path changes).
//   • NO `url` in the datasource — the URL lives in prisma.config.ts for the
//     CLI (migrate/db push), and the @prisma/adapter-pg driver adapter supplies
//     it to PrismaClient at runtime (see src/prisma/prisma.service.ts).
//   • DATABASE_URL is the direct `postgres://` URL of the local Prisma Postgres
//     server (`prisma dev` prints it — port 51214); the pg adapter needs a
//     plain postgres:// URL, not the `prisma+postgres://` proxy protocol.
// Rationale recorded in BACKEND_PLAN.md Phase 1.

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  runtime      = "nodejs"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// Native-app user account states (see BACKEND_PLAN.md "Auth model").
//   PENDING   — registered, credentials valid, but no access to app features.
//   ACTIVE    — validated with the global activation code; full access.
//   SUSPENDED — access revoked by an admin from the dashboard (ActiveUserGuard
//               denies anything other than ACTIVE, so suspended users are
//               locked out until reactivated).
enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

// Roles let the same table back both native-app members and dashboard admins.
// The dashboard login rejects non-ADMIN roles; the native app is for MEMBERs.
enum UserRole {
  MEMBER
  ADMIN
}

model User {
  id       String @id @default(cuid())
  // Registration only requires username + password (privacy — BACKEND_PLAN /
  // WIRING_PLAN B1). firstName/lastName/email are optional: kept nullable for
  // the seeded admin (who logs into the dashboard by email) and any legacy
  // rows, but native sign-up never sets them.
  firstName    String?
  lastName     String?
  email        String?    @unique
  username     String     @unique
  passwordHash String
  role         UserRole   @default(MEMBER)
  status       UserStatus @default(PENDING)
  isActivated  Boolean    @default(false)

  // Audit trail for activation. `activationCodeUsed` records WHICH code the
  // user activated with, so a later admin change to the global code never
  // affects them, and a future migration to per-user invite codes is trivial.
  activatedAt        DateTime?
  activationCodeUsed String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// Global application settings — a single-row (singleton) table. The activation
// code is stored here, never hardcoded. Changing it only affects FUTURE
// activations (already-ACTIVE users are never re-checked).
model AppSettings {
  id             String   @id @default(cuid())
  activationCode String
  updatedAt      DateTime @updatedAt

  @@map("app_settings")
}

// ============================================================================
// Content (BACKEND_PLAN.md Phase 5). Field names mirror the native app's
// content types (PERLEDESLYS-Native-App/src/types/content.ts) so the app can
// swap mock-data for fetches with no UI changes. Images are stored as URL
// strings (the app renders remote URLs via expo-image); `ingredients`/`steps`
// are JSON to match the app's array shapes. Ids default to cuid but can be set
// explicitly (the seed uses the app's human slugs like "couscous-royal").
// ============================================================================

model Recipe {
  id          String   @id @default(cuid())
  title       String
  image       String
  time        String
  difficulty  String // "Facile" | "Moyen" | "Avancé"
  category    String
  portions    Int
  description String
  cookidooUrl String
  isNew       Boolean  @default(false)
  ingredients Json // [{ label, qty }]
  steps       Json // string[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("recipes")
}

model Video {
  id          String   @id @default(cuid())
  title       String
  image       String
  duration    String
  category    String
  description String
  // Vimeo link the admin pastes (vimeo.com/ID?h=HASH or player URL). The app
  // parses id+hash from it and plays via the Vimeo player. (WIRING_PLAN B4)
  vimeoUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("videos")
}

model Article {
  id        String   @id @default(cuid())
  title     String
  excerpt   String
  image     String
  readTime  String
  category  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("articles")
}

model Live {
  id          String   @id @default(cuid())
  title       String
  date        String
  time        String
  image       String
  status      String // "À venir" | "En direct" | "Replay"
  description String
  platform    String
  // Vimeo link for the live stream / replay (WIRING_PLAN B4).
  vimeoUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("lives")
}

model Event {
  id          String   @id @default(cuid())
  title       String
  date        String // ISO yyyy-mm-dd
  time        String
  type        String // "live" | "atelier" | "publication" | "rappel"
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("events")
}

model FaqItem {
  id        String   @id @default(cuid())
  q         String
  a         String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("faq_items")
}

// Singletons — one row each.
model WelcomeMessage {
  id        String   @id @default(cuid())
  subject   String
  body      String
  updatedAt DateTime @updatedAt

  @@map("welcome_message")
}

model FounderInfo {
  id        String   @id @default(cuid())
  name      String
  fullName  String
  bio       String
  avatar    String
  updatedAt DateTime @updatedAt

  @@map("founder_info")
}
